# macOS
.DS_Store

# Editor / tooling local state
.claude/settings.local.json
.idea/
.vscode/

# Internal working files — deliberately not published
CLAUDE.md
docs/TODO.md
docs/phases.md

# Environments and secrets
.env
.env.*
*.key
*.pem

# Never commit real financial data — the benchmark corpus stays local.
# Match bench-data anywhere (repo root OR bench/bench-data), plus common doc types.
bench-data/
/corpus/
/statements/
*.pdf
*.PDF

# viva-bench live configs (may reference institution names) — examples are committed
bench/corpus.yaml
bench/models.yaml

# Never commit a real ledger vault (encrypted, but still the user's data).
*.vault
product/**/*.jsonl
*.blob
raw-header.json
.viva-vault/

# viva-bench local artifacts
bench/.venv/
bench/__pycache__/
bench/**/__pycache__/
bench/.pytest_cache/
bench/*.egg-info/
bench/**/*.egg-info/

# Python build artifacts (any package)
__pycache__/
**/__pycache__/
*.egg-info/
**/*.egg-info/
.pytest_cache/
**/.pytest_cache/
